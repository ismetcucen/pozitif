rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Ortak yardımcı
    function isAuthenticated() {
      return request.auth != null;
    }

    // Dosya boyutu max 20MB
    function isValidSize() {
      return request.resource.size < 20 * 1024 * 1024;
    }

    // İzin verilen dosya türleri
    function isValidMimeType() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType.matches('application/pdf');
    }

    // Deneme dosyaları: her kullanıcı kendi klasörüne yükleyebilir
    match /exams/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
                   && request.auth.uid == userId
                   && isValidSize()
                   && isValidMimeType();
    }

    // Çalışma seansları kanıt fotoğrafları
    match /sessions/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
                   && request.auth.uid == userId
                   && isValidSize()
                   && isValidMimeType();
    }

    // Profil fotoğrafları
    match /profiles/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
                   && request.auth.uid == userId
                   && isValidSize()
                   && request.resource.contentType.matches('image/.*');
    }

    // Blog görselleri (Admin tarafından yüklenir)
    match /blog/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Diğer tüm yollar — varsayılan: yalnızca authenticated
    match /{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if false; // açıkça belirtilmemiş yollar yasak
    }
  }
}
